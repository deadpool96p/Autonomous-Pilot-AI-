{
  "name": "autonomous-vehicle-simulation",
  "version": "1.0.0",
  "description": "Unified runner for simulation",
  "scripts": {
    "install:backend": "python -m pip install -r backend/requirements.txt",
    "install:frontend": "cd frontend && npm install",
    "prestart": "npm run install:backend",
    "start:backend": "python -m uvicorn backend.main:app --host 0.0.0.0 --port 8000",
    "start:frontend": "cd frontend && npm run dev",
    "dev": "concurrently --kill-others \"npm run start:backend\" \"npm run start:frontend\"",
    "start": "npm run dev"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "sqlalchemy": "^10.1.1"
  }
}
